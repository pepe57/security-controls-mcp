# Include documentation
include *.md
include *.toml
include *.json
include *.yaml
include *.yml
include *.txt
include *.lock
include *.premium
include LICENSE
include .gitleaks.toml
include .pre-commit-config.yaml
include Dockerfile
include Dockerfile.premium
include server.json
include sources.yml

# Include docs directory
recursive-include docs *.md

# Include test files
recursive-include tests *.py
recursive-include tests *.md

# Include scripts
include *.py
recursive-include scripts *.py
recursive-include scripts *.json
recursive-include scripts *.xlsx
recursive-include scripts *.txt

# Include API and fixtures
recursive-include api *.py
recursive-include fixtures *.json

# Exclude compiled Python files and stale backups
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.so
global-exclude .DS_Store
global-exclude *-e
